# RetroFuturism — environment variables
#
# Copy to `.env` and adjust as needed. `.env` is gitignored.
#
# NOTE: This project intentionally has very few runtime env vars. The SQLite
# database path ("./data.db") and drizzle config are currently hard-coded in
# server/storage.ts and drizzle.config.ts rather than read from the environment.
# There is no auth/session/OAuth layer in the current codebase, so no secrets
# are required to run it.

# Node environment: "development" (default via `npm run dev`) or "production"
# (set automatically by `npm start`). Controls whether Vite dev middleware or
# the prebuilt static client is served.
NODE_ENV=development

# Port the Express server (API + client) listens on. Defaults to 5000.
PORT=5000
